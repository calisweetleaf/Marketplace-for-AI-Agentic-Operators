{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constitutional Prompt Audit Report",
  "type": "object",
  "required": ["overall_score", "readiness", "recommended_route", "findings", "scorecard", "red_team"],
  "properties": {
    "overall_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "readiness": {"type": "string"},
    "recommended_route": {"type": "string", "enum": ["patch", "section_refactor", "constitutional_rewrite"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence", "impact", "fix"],
        "properties": {
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "title": {"type": "string"},
          "evidence": {"type": "string"},
          "impact": {"type": "string"},
          "fix": {"type": "string"}
        }
      }
    },
    "scorecard": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 10}},
    "red_team": {"type": "array", "items": {"type": "object"}}
  }
}
