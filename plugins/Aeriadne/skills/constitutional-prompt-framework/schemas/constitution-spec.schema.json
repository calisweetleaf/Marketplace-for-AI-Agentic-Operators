{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/constitutional-prompt-framework/constitution-spec.schema.json",
  "title": "Agent Constitution Spec",
  "type": "object",
  "required": ["identity", "authority", "roe", "doctrine", "persona", "capabilities", "memory", "outputs", "evaluation", "status"],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["agent_name", "agent_type", "mission", "success_conditions"],
      "properties": {
        "agent_name": {"type": "string"},
        "agent_type": {"type": "string"},
        "mission": {"type": "string"},
        "scope": {"type": "array", "items": {"type": "string"}},
        "non_goals": {"type": "array", "items": {"type": "string"}},
        "success_conditions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "authority": {
      "type": "object",
      "required": ["hierarchy", "approval_gates", "conflict_handling", "refusal_behavior"],
      "properties": {
        "hierarchy": {"type": "array", "items": {"type": "string"}},
        "approval_gates": {"type": "array", "items": {"type": "string"}},
        "conflict_handling": {"type": "string"},
        "refusal_behavior": {"type": "string"}
      }
    },
    "roe": {"type": "array", "items": {"$ref": "#/$defs/rule"}},
    "doctrine": {"type": "array", "items": {"$ref": "#/$defs/principle"}},
    "persona": {
      "type": "object",
      "properties": {
        "archetype": {"type": "string"},
        "voice": {"type": "array", "items": {"type": "string"}},
        "posture": {"type": "array", "items": {"type": "string"}},
        "behavioral_defaults": {"type": "array", "items": {"type": "string"}}
      }
    },
    "capabilities": {"type": "array", "items": {"$ref": "#/$defs/capability"}},
    "domain": {
      "type": "object",
      "properties": {
        "canonical_facts": {"type": "array", "items": {"type": "string"}},
        "glossary": {"type": "object", "additionalProperties": {"type": "string"}},
        "entities": {"type": "array", "items": {"type": "string"}},
        "workflows": {"type": "array", "items": {"type": "string"}},
        "open_questions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "memory": {
      "type": "object",
      "required": ["availability", "remember", "do_not_remember", "fallback"],
      "properties": {
        "availability": {"type": "string"},
        "remember": {"type": "array", "items": {"type": "string"}},
        "do_not_remember": {"type": "array", "items": {"type": "string"}},
        "scope": {"type": "string"},
        "fallback": {"type": "string"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "acceptance_gate": {"type": "string"},
        "red_team_probes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "status": {
      "type": "object",
      "required": ["version", "last_updated", "owner", "target_platform"],
      "properties": {
        "version": {"type": "string"},
        "last_updated": {"type": "string"},
        "owner": {"type": "string"},
        "target_platform": {"type": "string"},
        "known_risks": {"type": "array", "items": {"type": "string"}},
        "pending_revisions": {"type": "array", "items": {"type": "string"}},
        "changelog": {"type": "string"}
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["name", "trigger", "rule", "rationale", "violation_surface", "recovery"],
      "properties": {
        "name": {"type": "string"},
        "trigger": {"type": "string"},
        "rule": {"type": "string"},
        "rationale": {"type": "string"},
        "violation_surface": {"type": "string"},
        "recovery": {"type": "string"}
      }
    },
    "principle": {
      "type": "object",
      "required": ["name", "principle", "rationale", "failure_mode", "required_behavior"],
      "properties": {
        "name": {"type": "string"},
        "principle": {"type": "string"},
        "rationale": {"type": "string"},
        "failure_mode": {"type": "string"},
        "required_behavior": {"type": "string"}
      }
    },
    "capability": {
      "type": "object",
      "required": ["name", "trigger", "use", "do_not_use", "verification", "approval_gate", "fallback"],
      "properties": {
        "name": {"type": "string"},
        "trigger": {"type": "string"},
        "use": {"type": "string"},
        "do_not_use": {"type": "string"},
        "verification": {"type": "string"},
        "approval_gate": {"type": "string"},
        "fallback": {"type": "string"}
      }
    }
  }
}
